# -----------------------------------------------------------------------------
# Engineering GPT production environment template
# Store these values in your hosting provider secret manager. Do not commit real secrets.
# -----------------------------------------------------------------------------

# Application
NEXT_PUBLIC_APP_NAME="Engineering GPT"
NEXT_PUBLIC_APP_ENV="production"
NEXT_PUBLIC_DEMO_MODE="false"
APP_BASE_URL="https://your-domain.example"

# AI provider
AI_PROVIDER="openai-compatible"
AI_LIVE_ENABLED="true"
AI_API_KEY="replace-with-provider-secret"
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="replace-with-chat-completions-model"
AI_TIMEOUT_MS="30000"
AI_TEMPERATURE="0.2"
AI_RESPONSE_FORMAT_JSON="true"

# Database - required in production
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/engineering_gpt?schema=public"
REQUIRE_PHASE5_DATABASE="true"

# Phase 5 auth bridge until Phase 6 is implemented
# Enable trusted headers only behind a secure reverse proxy/auth gateway.
ENABLE_LOCAL_DEV_USER="false"
ENABLE_TRUSTED_AUTH_HEADERS="true"
LOCAL_DEV_USER_EMAIL=""
LOCAL_DEV_USER_NAME=""
REQUIRE_PHASE3_AUTH_CONTEXT="false"

# Phase 6 auth reserved values
AUTH_SECRET="replace-with-a-strong-secret"
AUTH_TRUST_HOST="true"
AUTH_REQUIRE_EMAIL_VERIFICATION="true"
AUTH_MFA_OPTIONAL="true"

# Phase 7 storage/retrieval reserved values
OBJECT_STORAGE_PROVIDER="s3-compatible"
OBJECT_STORAGE_BUCKET=""
OBJECT_STORAGE_REGION=""
OBJECT_STORAGE_ENDPOINT=""
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
VECTOR_DATABASE_URL=""
EMBEDDING_MODEL=""

# Security and safety
EXPOSE_INSTRUCTION_HIERARCHY_PREVIEW="false"
ENGINEERING_SCOPE_ENFORCEMENT="true"
SAFETY_POST_PROCESSOR="true"
AUDIT_LOGGING_ENABLED="true"
