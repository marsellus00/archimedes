# -----------------------------------------------------------------------------
# Engineering GPT environment template
# Phase 5: production-ready database integration with Phase 6 auth bridge
# Copy this file to .env.local for local development or to your deployment secret store.
# Do not commit real secrets.
# -----------------------------------------------------------------------------

# Application
NEXT_PUBLIC_APP_NAME="Engineering GPT"
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_DEMO_MODE="false"
APP_BASE_URL="http://localhost:3000"

# AI provider - Phase 3/5 integration
# mock = deterministic local provider; openai-compatible = live chat-completions API.
AI_PROVIDER="mock"
AI_LIVE_ENABLED="false"
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL=""
AI_TIMEOUT_MS="30000"
AI_TEMPERATURE="0.2"
AI_RESPONSE_FORMAT_JSON="true"

# Database - Phase 5 implementation
# Required for production and for persisted projects, chats, calculations, files, and audit logs.
DATABASE_URL="postgresql://engineering_gpt:engineering_gpt@localhost:5432/engineering_gpt?schema=public"
REQUIRE_PHASE5_DATABASE="false"

# Phase 5 trusted-user context bridge
# Full session auth, MFA, email verification, and account pages are Phase 6.
# Local development may use the built-in local user. Production should use a trusted gateway/auth layer.
ENABLE_LOCAL_DEV_USER="true"
LOCAL_DEV_USER_EMAIL="local.engineer@example.com"
LOCAL_DEV_USER_NAME="Local Engineer"
ENABLE_TRUSTED_AUTH_HEADERS="false"

# Optional trusted headers when ENABLE_TRUSTED_AUTH_HEADERS=true:
# x-engineering-user-id
# x-engineering-user-email
# x-engineering-user-name

# Legacy Phase 3 development auth context compatibility
REQUIRE_PHASE3_AUTH_CONTEXT="false"

# Authentication - Phase 6 reserved values
AUTH_SECRET="replace-with-a-strong-secret"
AUTH_TRUST_HOST="true"
AUTH_REQUIRE_EMAIL_VERIFICATION="true"
AUTH_MFA_OPTIONAL="true"

# Object storage for uploaded engineering files - Phase 7 reserved values
OBJECT_STORAGE_PROVIDER="s3-compatible"
OBJECT_STORAGE_BUCKET=""
OBJECT_STORAGE_REGION=""
OBJECT_STORAGE_ENDPOINT=""
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""

# Document retrieval / vector storage - Phase 7 reserved values
VECTOR_DATABASE_URL=""
EMBEDDING_MODEL=""

# Instruction hierarchy preview
EXPOSE_INSTRUCTION_HIERARCHY_PREVIEW="false"

# Safety and audit behavior
ENGINEERING_SCOPE_ENFORCEMENT="true"
SAFETY_POST_PROCESSOR="true"
AUDIT_LOGGING_ENABLED="true"
